{
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @kasify/dashboard build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": "@kasify_api_url",
    "NEXT_PUBLIC_DASHBOARD_URL": "@kasify_dashboard_url",
    "NEXT_PUBLIC_STOREFRONT_URL": "@kasify_storefront_url"
  }
}
