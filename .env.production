# ═══════════════════════════════════════════════════════════════
#  KStack — Production Environment Variables
#  Copy this to .env on your server and fill in every value.
#  NEVER commit this file to git.
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=kstack
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=kstack

# Full connection string (used by the API and Drizzle migrations)
DATABASE_URL=postgresql://kstack:CHANGE_ME_strong_password_here@postgres:5432/kstack

# ── Auth secrets ────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_min_32_chars

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your dashboard + storefront URLs)
ALLOWED_ORIGINS=https://dashboard.yourdomain.com,https://yourdomain.com

# ── App URLs (used by Next.js frontends) ────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.yourdomain.com
NEXT_PUBLIC_STOREFRONT_URL=https://yourdomain.com
# Root domain for subdomain store routing (e.g. mystore.yourdomain.com)
NEXT_PUBLIC_ROOT_DOMAIN=yourdomain.com

# ── Email / SMTP ────────────────────────────────────────────────
# Any SMTP provider: Mailgun, Postmark, SendGrid, Gmail, etc.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ── AI providers (optional — merchants add their own keys) ──────
# These are fallback/default keys. Merchants can override per store.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── File storage / S3 (optional) ────────────────────────────────
# Leave blank to use local filesystem (not recommended for production)
S3_BUCKET=kstack-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
# For Cloudflare R2, MinIO etc — set custom endpoint:
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ── Node ────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001

# ── KStack License ───────────────────────────────────────────────
# Community plan is free (leave blank). Pro/Enterprise key from https://kstack.dev/pricing
KSTACK_LICENSE_KEY=

# ── Telemetry ────────────────────────────────────────────────────
# Anonymous usage data only (install ID, version, tenant count). Set to false to opt out.
KSTACK_TELEMETRY=true
