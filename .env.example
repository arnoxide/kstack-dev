# Database
DATABASE_URL=postgresql://kasify:kasify@localhost:5432/kasify

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars

# App
NODE_ENV=development
API_PORT=3001
GATEWAY_PORT=3000

# Storefront
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BASE_DOMAIN=kasify.localhost

# Storage (Cloudflare R2 / S3)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=kasify-dev
STORAGE_PUBLIC_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@kasify.com
