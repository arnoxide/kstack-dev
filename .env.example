# Database
DATABASE_URL=postgresql://kstack:kstack@localhost:5432/kstack

# Redis
REDIS_URL=redis://localhost:6379

# Auth
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars

# App
NODE_ENV=development
API_PORT=3001
GATEWAY_PORT=3000

# Storefront
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BASE_DOMAIN=kstack.localhost
# Root domain for subdomain store routing (e.g. slug.yourdomain.com)
# Leave unset in local dev — stores are accessed at localhost:3003/[slug]
NEXT_PUBLIC_ROOT_DOMAIN=yourdomain.com

# Storage (Cloudflare R2 / S3)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=kstack-dev
STORAGE_PUBLIC_URL=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Email (Resend / SMTP)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── KStack License ───────────────────────────────────────────────
# Community plan is free and open source (no key needed).
# A license key unlocks Pro / Enterprise features.
# Get one at: https://kstack.dev/pricing
KSTACK_LICENSE_KEY=

# ── Telemetry ────────────────────────────────────────────────────
# KStack collects anonymous usage data (install ID, version, tenant count).
# No personal or store data is ever sent. Set to false to opt out.
# Learn more: https://kstack.dev/docs/telemetry
KSTACK_TELEMETRY=true
